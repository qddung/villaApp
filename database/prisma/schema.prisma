// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

generator backendClient {
  provider      = "prisma-client-js"
  output        = "../../backend/prisma/generated/client"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Settings {
  id                          String @id @default(uuid())
  bookingConfirmationTemplate String?
  contactEmail                String?
  contactPhone                String?
  contactAddress              String?
  siteName                    String? @default("TungLuongVilla")
  heroTitle                   String? @default("Villa Căn Hộ Cao Cấp")
  heroHighlight               String? @default("Tại Vũng Tàu")
  heroDescription             String? @default("Khám phá bộ sưu tập villa được chọn lọc kỹ lưỡng với hồ bơi riêng, view biển tuyệt đẹp và dịch vụ 24/7")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@map("settings")
}

model Villa {
  id            String           @id @default(uuid())
  slug          String           @unique
  name          String
  tagline       String
  description   String
  areaId        String?
  areaObj       Area?            @relation(fields: [areaId], references: [id])
  address       String
  bedrooms      Int
  bathrooms     Int
  maxGuests     Int
  size          Int              // m2
  pricePerNight Float
  priceWeekend  Float
  priceHoliday  Float
  rating        Float
  reviewCount   Int
  checkIn       String
  checkOut      String
  featured      Boolean
  lat           Float
  lng           Float
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  images         VillaImage[]
  amenities      VillaAmenity[]
  highlights     VillaHighlight[]
  policies       VillaPolicy[]
  reviews        Review[]
  bookings       Booking[]
  @@map("villas")
}


model Booking {
  id        String   @id @default(uuid())
  villaId   String?
  villa     Villa?   @relation(fields: [villaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  name      String
  email     String
  phone     String
  note      String?
  checkIn   String
  checkOut  String
  guests         Int
  total          Float
  priceAtBooking Float?
  bookingType    String   @default("APP") // APP hoặc ZALO
  status         String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookings")
}

model VillaImage {
  id       String  @id @default(uuid())
  villaId  String?
  data     Bytes
  mimeType String  @default("image/jpeg")
  isMain   Boolean @default(false)
  order    Int     @default(0)

  villa Villa? @relation(fields: [villaId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("villa_images")
}

model Amenity {
  id       Int      @id @default(autoincrement())
  slug     String   @unique
  name     String
  icon     String
  category Int      @default(6)

  villas   VillaAmenity[]

  @@map("amenities")
}

model VillaAmenity {
  villaId   String
  amenityId Int

  villa     Villa   @relation(fields: [villaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([villaId, amenityId])
  @@map("villa_amenities")
}

model VillaHighlight {
  id      String @id @default(cuid())
  text    String
  order   Int    @default(0)
  villaId String

  villa Villa @relation(fields: [villaId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("villa_highlights")
}

model VillaPolicy {
  id      String @id @default(cuid())
  text    String
  order   Int    @default(0)
  villaId String

  villa Villa @relation(fields: [villaId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("villa_policies")
}

model Review {
  id      String @id @default(cuid())
  author  String
  avatar  String   @default("")
  date    String
  rating  Float
  comment String
  villaId String

  villa Villa @relation(fields: [villaId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("reviews")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String?  @unique
  password  String
  fullName  String?
  phone     String?
  role      String   @default("pending") // pending, pending_owner, owner, admin, staff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Area {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  isFamous    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  villas    Villa[]
  image     ImageArea?

  @@map("areas")
}

model ImageArea {
  id       String @id @default(uuid())
  areaId   String @unique
  data     Bytes
  mimeType String @default("image/jpeg")

  area     Area   @relation(fields: [areaId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("image_areas")
}
